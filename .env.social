# Social Media Meta Tags Configuration
# Add these to your .env file

# Default OG Image URL (1200x630 px recommended)
DEFAULT_OG_IMAGE=https://survey.pcru.ac.th/og-image.jpg

# Site Information
APP_NAME=Survey
APP_DESCRIPTION=Survey Application

# Social Media Handles (Optional)
TWITTER_SITE=@yourhandle
TWITTER_CREATOR=@yourhandle

# Default Locale
DEFAULT_LOCALE=th_TH
